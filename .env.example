# Copy to .env.local and fill in. .env.local is gitignored; never commit real values.
# Generate the two secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

# ─── Database ────────────────────────────────────────────────────────────────
# Use the SUPAVISOR TRANSACTION POOLER string (port 6543), not the direct
# connection on 5432. Two reasons, both of which bite in production only:
#
#  1. Direct connections to Supabase are IPv6-only unless you pay for the IPv4
#     add-on. Vercel's functions are IPv4, so the direct string resolves locally
#     on a home connection and then fails to connect once deployed.
#  2. Every serverless invocation opens its own connection. The free tier allows
#     60 direct connections but 200 pooler clients, and a burst of traffic
#     exhausts the former long before the latter.
#
# Find it in Supabase: Connect -> Transaction pooler. It looks like
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Caveat that follows from the pooler: transaction mode does NOT support
# prepared statements. Keep `prepare: false` on the client.
DATABASE_URL=

# The direct 5432 string, used only by migrations run from your machine — they
# want a real session and DDL, not a transaction-pooled connection.
DIRECT_URL=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Minimum 32 characters; the app refuses to boot on anything shorter.
JWT_ACCESS_SECRET=
# Minimum 16. Added to every password before hashing, so an attacker holding a
# database dump still cannot brute-force offline without also having this.
# Changing it invalidates every existing password — treat it as permanent.
ARGON2_PEPPER=

# ─── Google OAuth ────────────────────────────────────────────────────────────
# console.cloud.google.com/auth -> Clients -> Web application.
# The client ID is public (it ships in redirect URLs); the secret is not.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must byte-match an Authorized redirect URI in the console — trailing slashes
# and http-vs-https count as different URIs.
#   local: http://localhost:3000/api/v1/auth/google/callback
#   prod:  https://starrytv.vercel.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── App ─────────────────────────────────────────────────────────────────────
# Where the app believes it is. Used to build absolute URLs in emails and to
# decide whether cookies get the Secure flag.
APP_ORIGIN=http://localhost:3000

# ─── Email (Phase 2) ─────────────────────────────────────────────────────────
# Supabase's built-in mailer is capped at 2 messages/hour on a best-effort
# basis, so verification silently fails for the second signup in any hour.
# Resend's free tier is 3,000/month.
RESEND_API_KEY=
EMAIL_FROM=Starry <hello@starrytv.app>
